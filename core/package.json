{
  "name": "@kenrick95/c4",
  "version": "5.1.1",
  "description": "Building blocks for a Connect Four game",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenrick95/c4.git"
  },
  "author": {
    "name": "Kenrick",
    "email": "kenrick95@gmail.com",
    "url": "https://kenrick95.org"
  },
  "bugs": {
    "url": "https://github.com/kenrick95/c4/issues"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/c4.cjs",
    "module": "./dist/c4.js",
    "unpkg": "./dist/c4.umd.cjs",
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "import": {
          "types": "./dist/lib.d.ts",
          "default": "./dist/c4.js"
        },
        "require": {
          "types": "./dist/lib.d.cts",
          "default": "./dist/c4.cjs"
        }
      }
    },
    "types": "./dist/lib.d.ts"
  },
  "homepage": "https://github.com/kenrick95/c4",
  "license": "MIT",
  "keywords": [
    "c4",
    "connect-four",
    "game"
  ],
  "source": "src/lib.ts",
  "main": "./src/lib.ts",
  "module": "./src/lib.ts",
  "umd:main": "./dist/c4.umd.cjs",
  "unpkg": "./dist/c4.umd.cjs",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/lib.ts"
  },
  "types": "./src/lib.ts",
  "files": [
    "src/",
    "dist/"
  ],
  "scripts": {
    "prepack": "yarn build",
    "dev": "vite",
    "build": "vite build",
    "check-package-json": "node ./check-package-json.js",
    "test": "vitest --watch=false"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "24",
    "typescript": "~6.0.3",
    "vite": "^8.0.5",
    "vite-dts": "^1.0.4",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
